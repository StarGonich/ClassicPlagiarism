n = int(input())
a = []
for i in range(n):
    a.append(list(map(int, input().split())))
unordered = True
while unordered:
    unordered = False
    for j in range(n - 1):
        if a[j][1] < a[j + 1][1]:
            a[j], a[j + 1] = a[j + 1], a[j]
            unordered = True
        elif a[j][1] == a[j + 1][1]:
            if a[j][0] > a[j + 1][0]:
                a[j], a[j + 1] = a[j + 1], a[j]
    n -= 1
for i in a:
    print(*i)
