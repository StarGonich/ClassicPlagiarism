# Пример кода для поиска пяти чисел по условиям
# Условия: числа должны быть уникальными, положительными и сумма должна быть равна 50

# Создаем список для хранения подходящих чисел
result_numbers = []

# Перебираем возможные числа от 1 до 50
for a in range(1, 50):
    for b in range(1, 50):
        for c in range(1, 50):
            for d in range(1, 50):
                for e in range(1, 50):
                    # Проверяем условия: уникальность, сумма и положительность
                    if len({a, b, c, d, e}) == 5 and a + b + c + d + e == 50:
                        result_numbers.append((a, b, c, d, e))

# Выводим найденные числа
print("Найденные числа:")
for nums in result_numbers:
    print(nums)