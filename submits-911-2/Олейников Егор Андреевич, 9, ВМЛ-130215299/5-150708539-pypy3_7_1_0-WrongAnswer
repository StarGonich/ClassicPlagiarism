n = int(input())
p = [int(x) for x in input().split()]
k = int(input())
fr = [int(x) - 1 for x in input().split()]
tp = 0
fp = 0
tn = 0
fn = 0
tmax = -1
f1 = -1
x = -1
for t in range(n):
    for i in range(n):
        if p[i] >= p[t]:
            if i in fr:
                tp += 1
            else:
                fp += 1
        else:
            if i in fr:
                fn += 1
            else:
                tn += 1
    pr = tp / (tp + fp)
    r = tp / (tp + fn)
    if pr == 0 and r == 0:
        f = 0
        if f > f1:
            f1 = f
            tmax = p[t]
            x = t
    else:
        f = 2 * pr * r / (pr + r)
        if f > f1:
            f1 = f
            tmax = p[t]
            x = t
    tp = 0
    fp = 0
    tn = 0
    fn = 0
if x != 0:
    print(p[x - 1] + 1)
else:
    print(tmax)