import math

def euclidean_distance(p1, p2):
    return math.sqrt((p1[0] - p2[0])**2 + (p1[1] - p2[1])**2)

def solve():
    n = int(input())
    points = []
    for _ in range(n):
        x, y, c = map(int, input().split())
        points.append((x, y, c))

    results = {}

    for k in range(1, n, 2):
        correct_predictions = 0
        for i in range(n):
            current_point = points[i]
            other_points_with_distances = []

            for j in range(n):
                if i != j:
                    dist = euclidean_distance(current_point, points[j])
                    other_points_with_distances.append((dist, points[j][2]))

            # Sort by distance
            other_points_with_distances.sort()

            # Get k nearest neighbors
            k_nearest_neighbors = other_points_with_distances[:k]

            # Count colors among neighbors
            color_counts = {0: 0, 1: 0}
            for _, color in k_nearest_neighbors:
                color_counts[color] += 1

            # Determine predicted color
            predicted_color = 0
            if color_counts[1] > color_counts[0]:
                predicted_color = 1

            # Compare with actual color
            if predicted_color == current_point[2]:
                correct_predictions += 1
        results[k] = correct_predictions

    # Print results for odd k up to n-1
    for k in range(1, n, 2):
        print(results[k])

if __name__ == "__main__":
    solve()