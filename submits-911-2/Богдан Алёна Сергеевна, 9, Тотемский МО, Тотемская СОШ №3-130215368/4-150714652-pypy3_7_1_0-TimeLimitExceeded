import math  
from collections import Counter

def euclidean_distance(point1, point2):
    return math.sqrt((point1[0] - point2[0]) ** 2 + (point1[1] - point2[1]) ** 2)

def classify_points(n, points):
    results = []
    
    # Loop over odd k values  
    for k in range(1, n, 2):
        correct_count = 0
        
        for i in range(n):
            # Compute distances from point i to all other points  
            distances = []
            for j in range(n):
                if i != j:  # Don't include the point itself  
                    distance = euclidean_distance(points[i][:2], points[j][:2])
                    distances.append((distance, points[j][2]))  # (distance, color)
            
            # Sort by distance  
            distances.sort(key=lambda x: x[0])
            
            # Get the k nearest neighbors  
            nearest_neighbors = distances[:k]
            colors = [color for _, color in nearest_neighbors]
            
            # Determine the most common color  
            most_common_color = Counter(colors).most_common(1)[0][0]
            
            # Check if the predicted color is the same as the actual color  
            if most_common_color == points[i][2]:
                correct_count += 1
        
        results.append(correct_count)
    
    return results

# Read input data  
n = int(input().strip())
points = []

for _ in range(n):
    x, y, c = map(int, input().strip().split())
    points.append((x, y, c))

# Get results  
results = classify_points(n, points)

# Print results  
for count in results:
    print(count)
