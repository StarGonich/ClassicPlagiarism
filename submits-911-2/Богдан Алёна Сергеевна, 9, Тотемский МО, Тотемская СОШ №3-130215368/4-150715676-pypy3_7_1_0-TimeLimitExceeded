def distance(p1, p2):
    """Вычисляет евклидово расстояние между двумя точками."""
    return ((p1[0] - p2[0])**2 + (p1[1] - p2[1])**2)**0.5

def classify(points, target_index, k):
    """Классифицирует точку, используя k ближайших соседей."""
    target = points[target_index]
    distances = []
    for i, point in enumerate(points):
        if i != target_index:
            distances.append((distance(target, point), point[2]))  # (расстояние, цвет)
    distances.sort()

    # Берем k ближайших соседей
    neighbors = distances[:k]

    # Определяем цвет, который встречается чаще
    black_count = sum(neighbor[1] for neighbor in neighbors)
    white_count = k - black_count

    return 1 if black_count > white_count else 0

n = int(input())
points = []
for _ in range(n):
    x, y, c = map(int, input().split())
    points.append((x, y, c))

for k in range(1, n, 2):
    correct_predictions = 0
    for i in range(n):
        predicted_color = classify(points, i, k)
        if predicted_color == points[i][2]:
            correct_predictions += 1
    print(correct_predictions)
