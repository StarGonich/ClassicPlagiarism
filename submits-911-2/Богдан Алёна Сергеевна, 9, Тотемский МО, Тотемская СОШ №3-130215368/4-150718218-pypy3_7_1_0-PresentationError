import math
from collections import Counter

def euclidean_distance(point1, point2):
    return math.sqrt((point1[0] - point2[0]) ** 2 + (point1[1] - point2[1]) ** 2)

def get_k_nearest_neighbors(points, target_point, k):
    distances = []
    for idx, point in enumerate(points):
        if point != target_point:
            distance = euclidean_distance(point[:2], target_point[:2])
            distances.append((distance, point))
    distances.sort(key=lambda x: x[0])  # сортируем по расстоянию
    return [point for _, point in distances[:k]]  # возвращаем k ближайших точек

def loo_cross_validation(points):
    n = len(points)
    results = {}
    
    for k in range(1, n, 2):  # перебираем нечетные значения k
        correct_count = 0
        
        for target_point in points:
            neighbors = get_k_nearest_neighbors(points, target_point, k)
            # Получаем цвета ближайших соседей
            neighbor_colors = [neighbor[2] for neighbor in neighbors]
            most_common_color = Counter(neighbor_colors).most_common(1)[0][0]
            if most_common_color == target_point[2]:  # сравниваем с истинным цветом
                correct_count += 1
        
        results[k] = correct_count
    
    return results

# Ввод данных
n = int(input())
points = [tuple(map(int, input().split())) for _ in range(n)]  # x, y, цвет

# Получаем результаты LOO-кросс-валидации
results = loo_cross_validation(points)

# Выводим результаты
for k, correct_count in results.items():
    print(f"k = {k}: {correct_count} correct classifications")

