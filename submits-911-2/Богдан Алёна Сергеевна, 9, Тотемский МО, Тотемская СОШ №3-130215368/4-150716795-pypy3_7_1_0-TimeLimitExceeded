import math

def distance(x1, y1, x2, y2):
    """Вычисляет евклидово расстояние между двумя точками."""
    return math.sqrt((x1 - x2)**2 + (y1 - y2)**2)

def solve():
    n = int(input())
    points = []
    for _ in range(n):
        x, y, c = map(int, input().split())
        points.append((x, y, c))

    for k in range(1, n, 2):
        correct_predictions = 0
        for i in range(n):
            # LOO: Исключаем текущую точку из рассмотрения.
            distances = []
            for j in range(n):
                if i != j:
                    dist = distance(points[i][0], points[i][1], points[j][0], points[j][1])
                    distances.append((dist, points[j][2]))

            # Находим k ближайших точек.
            distances.sort()
            nearest_neighbors = distances[:k]

            # Определяем цвет большинства среди k ближайших.
            black_count = sum(color for _, color in nearest_neighbors)
            white_count = k - black_count

            predicted_color = 1 if black_count > white_count else 0

            # Сравниваем предсказанный цвет с фактическим.
            if predicted_color == points[i][2]:
                correct_predictions += 1
        print(correct_predictions)

solve()
