
def find_numbers(x, y, z):
    # x - мода
    # y - медиана
    # z - среднее
    # Сначала найдем сумму всех чисел:
    total_sum = z * 5
    
    # Поскольку мода равна x, сделаем предположение о распределении чисел
    # Мода x должна встречаться как минимум 3 раза, чтобы быть единственной модой
    # Общая структура чисел может быть: [x, x, x, a, b], где a, b < x
    # для обеспечения медианы = y
    
    # Если среднее >= медиана, a и b должны быть меньшими и также учитываем, что
    # (x + x + x + a + b) / 5 = z
    # 3*x + a + b = total_sum
    
    # Можно начать с предположительных значений a и b
    for a in range(-10**9, 10**9 + 1):
        for b in range(a, 10**9 + 1):
            if a > x or b > x:
                continue
            # Условие для медианы
            numbers = [x, x, x, a, b]
            numbers.sort()
            median = numbers[2]  # Медиана - это третий элемент в отсортированном списке
            
            # Если медиана совпадает с заданной
            if median == y:
                # Проверяем среднее
                if (sum(numbers) == total_sum):
                    return numbers
            
    return -1

# Чтение входных данных
x = int(input())
y = int(input())
z = int(input())

result = find_numbers(x, y, z)
if result == -1:
    print(-1)
else:
    print(' '.join(map(str, result)))

