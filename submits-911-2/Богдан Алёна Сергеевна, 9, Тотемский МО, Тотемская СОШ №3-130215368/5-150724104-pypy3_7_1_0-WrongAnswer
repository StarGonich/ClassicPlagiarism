def find_best_threshold(N, P, K, fraud_indices):
    # Устанавливаем, что индексы фрод-сообщений начинаются с 0  
    fraud_set = set(fraud_indices)
    
    # Создаем список оценок и соответствующих им индексов, отмечая, является ли сообщение фродом  
    messages = [(P[i], i + 1 in fraud_set) for i in range(N)]
    
    # Сортируем сообщения по оценке P  
    messages.sort()  # Сортируем по первому элементу (оценки)
    
    # Инициализируем переменные для оценки  
    best_f1 = 0  
    best_threshold = 0
    
    # Инициализируем TP, FP, TN, FN  
    TP = 0  
    FP = 0  
    total_frauds = K
    
    # Идем по всем уникальным значениям P  
    unique_values = sorted(set(P))
    
    for threshold in unique_values:
        # Обновляем TP и FP  
        while messages and messages[0][0] < threshold:
            if messages[0][1]:  # Если это фрод  
                TP += 1  
            else:  # Если это не фрод  
                FP += 1  
            messages.pop(0)
        
        # Расчет метрик  
        if TP + FP > 0:
            precision = TP / (TP + FP)
        else:
            precision = 0
        
        recall = TP / total_frauds if total_frauds > 0 else 0
        
        # Расчет F1  
        if precision + recall > 0:
            F1 = 2 * precision * recall / (precision + recall)
        else:
            F1 = 0
        
        # Обновление наилучшего F1  
        if F1 > best_f1:
            best_f1 = F1  
            best_threshold = threshold  
        elif F1 == best_f1:
            best_threshold = min(best_threshold, threshold)
    
    return best_threshold


# Чтение входных данных  
N = int(input())
P = list(map(int, input().split()))
K = int(input())
fraud_indices = list(map(int, input().split()))

# Поиск наилучшего порога  
result = find_best_threshold(N, P, K, fraud_indices)
print(result)
