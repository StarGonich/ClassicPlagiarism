x, y, z = int(input()), int(input()), int(input())
if x < y:
    if z*5-(2*x+y)<=2*y+1:
        print(-1)
    else:
        print(x, x, y, y+1, z*5-2*x-2*y-1)
elif x>y:
    if z*5-(2*x+y)>=2*y-1:
        print(-1)
    else:
        print(z*5-(2*x+2*y-1), y-1, y, x, x)
elif x == y:
    print(x, x, x, x+1, z*5-4*x-1)