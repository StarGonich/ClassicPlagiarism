n = int(input())
pt = []
for _ in range(n):
   pt.append([int(t) for t in input().split()])
ans = [0] * n
for i in range(n):
   p = pt.copy()
   p.sort(key = lambda q : (q[0] - pt[i][0])**2 + (q[1] - pt[i][1])**2)
   color = [0, 0]
   for k in range(1, n):
      color[p[k][2]] += 1
      if k % 2 == 1:
         curcolor = 0 if color[0] > color[1] else 1
         if curcolor == pt[i][2]:
            ans[k] += 1   
print(*ans[1::2], sep='\n')
