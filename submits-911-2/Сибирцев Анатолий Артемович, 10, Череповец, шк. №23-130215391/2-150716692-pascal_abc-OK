program CorrectDiagnosisProbability;
var
  p1, p2, p3: Real;
  prob_all_correct: Real;
  prob_two_correct_one_incorrect: Real;
  total_probability: Real;
begin
  Readln(p1);
  Readln(p2);
  Readln(p3);
  prob_all_correct := p1 * p2 * p3;
  prob_two_correct_one_incorrect := p1 * p2 * (1 - p3);
  prob_two_correct_one_incorrect := prob_two_correct_one_incorrect + (p1 * (1 - p2) * p3);
  prob_two_correct_one_incorrect := prob_two_correct_one_incorrect + ((1 - p1) * p2 * p3);
  total_probability := prob_all_correct + prob_two_correct_one_incorrect;
  Writeln(total_probability:0:6);
end.