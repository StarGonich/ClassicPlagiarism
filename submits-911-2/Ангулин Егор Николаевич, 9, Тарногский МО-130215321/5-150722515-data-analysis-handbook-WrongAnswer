def main():
    # Считываем входные данные
    n = int(input())
    scores = list(map(int, input().split()))
    k = int(input())
    fraud_indices = set(map(lambda x: int(x) - 1, input().split()))  # Переводим в 0-based индексацию

    # Создаем список кортежей (оценка, является ли фродом)
    messages = [(scores[i], i in fraud_indices) for i in range(n)]

    # Сортируем сообщения по убыванию оценки
    messages.sort(key=lambda x: -x[0])

    # Инициализируем счетчики
    max_f1 = 0
    best_threshold = float('inf')
    tp = 0
    fp = 0
    fn = k  # Изначально все фрод-сообщения не обнаружены

    # Перебираем все возможные пороги
    for i in range(n):
        # Обновляем счетчики
        if messages[i][1]:
            tp += 1
            fn -= 1
        else:
            fp += 1

        # Пропускаем одинаковые оценки
        if i < n - 1 and messages[i][0] == messages[i + 1][0]:
            continue

        # Вычисляем метрики
        if tp == 0:
            precision = 0
            recall = 0
        else:
            precision = tp / (tp + fp)
            recall = tp / k

        if precision + recall == 0:
            f1 = 0
        else:
            f1 = 2 * precision * recall / (precision + recall)

        # Обновляем лучший порог
        if f1 > max_f1 or (f1 == max_f1 and messages[i][0] < best_threshold):
            max_f1 = f1
            best_threshold = messages[i][0]

    print(best_threshold)

if __name__ == "__main__":
    main()
