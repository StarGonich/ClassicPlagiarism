n = int(input())
points = []
for _ in range(n):
    x, y, c = map(int, input().split())
    points.append((x, y, c))

# Предварительно вычисляем матрицу расстояний
distances = [[0]*n for _ in range(n)]
for i in range(n):
    for j in range(i + 1, n):
        dx = points[i][0] - points[j][0]
        dy = points[i][1] - points[j][1]
        dist = dx*dx + dy*dy  # Можно сравнивать квадраты расстояний, чтобы избежать √
        distances[i][j] = dist
        distances[j][i] = dist

results = []

# Перебираем нечетные k от 1 до n-1
for k in range(1, n, 2):
    correct_count = 0
    for i in range(n):
        # Получить список расстояний до всех других точек
        dist_list = []
        for j in range(n):
            if i != j:
                dist_list.append((distances[i][j], j))
        # Отсортировать по расстоянию
        dist_list.sort(key=lambda x: x[0])
        # Взять k ближайших
        neighbors = dist_list[:k]
        # Подсчитать, какая чаще встречается цвет
        count_color = {0:0, 1:0}
        for _, idx in neighbors:
            c = points[idx][2]
            count_color[c] += 1
        # Предсказать цвет
        pred_color = 0 if count_color[0] >= count_color[1] else 1
        # Проверить, правильно ли предсказано
        if pred_color == points[i][2]:
            correct_count += 1
    results.append(correct_count)

# Вывести результаты
print(' '.join(map(str, results)))