p1 = float(input())
p2 = float(input())
p3 = float(input())

# Вероятности всех благоприятных исходов
P1 = p1 * p2 * p3
P2 = p1 * p2 * (1 - p3)
P3 = p1 * (1 - p2) * p3
P4 = (1 - p1) * p2 * p3

# Итоговая вероятность
result = P1 + P2 + P3 + P4

# Вывод с точностью до 4 знаков после запятой
print(f"{result:.4f}")
