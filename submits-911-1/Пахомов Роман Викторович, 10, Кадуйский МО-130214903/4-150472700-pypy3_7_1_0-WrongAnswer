from sys import stdin, stdout
from math import gcd
input = stdin.readline


def lcm(a, b):
    m = a * b
    while a != 0 and b != 0:
        if a > b:
            a %= b
        else:
            b %= a
    return m // (a + b)

def main():
    n = int(input())
    k = int(input())
    
    min_lcm = 10**4
    min_res = 0
    for p in range(n+1, n+k+1, gcd(n+1, k)):
        # print(lcm(n, p), p, n, k, gcd(n, k))
        # q[lcm(n, p)] = p
        l = lcm(n, p)
        if l < min_lcm:
            min_lcm = l
            min_res = p

    stdout.write(str(min_res))

main()