n = int(input())
k = int(input())
min_NOK = 1000000000
for i in range(n + 1, n + k + 1):
    p = i * n
    n1 = n
    i1 = i
    NOK = 0
    while n1 != i1:
        if n1 > i1:
            n1 -= i1
        else:
            i1 -= n1
    NOK = p / n1
    if NOK < min_NOK:
        min_NOK = NOK
        f = i
print(f)