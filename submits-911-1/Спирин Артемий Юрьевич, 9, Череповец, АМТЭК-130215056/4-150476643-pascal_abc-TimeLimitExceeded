program ln4;
var potv,otv,nok,nod,a,b,n,k,pmin,pmax,p:int64;
begin
  readln(n,k);
  pmin:=n+1;
  pmax:=n+k;
  a:=n;
  otv:=1000000000;
  for p:=pmin to pmax do begin
  b:=p;
  a:=n;
  while a<>b do begin
    if (a>b) then begin
      a:=a-b;
      end
    else if (b>a) then begin
    b:=b-a;
    end;
  end;
  nod:=a;
  nok:=(n*p) div nod;;
  if (nok < otv) then begin
    otv:=nok;
    potv:=p;
  end;
  end;
  writeln(potv);
end.