from math import sqrt
def dels(n):
    m = set()
    for i in range(1, int(sqrt(n)) + 1):
        if n % i == 0:
            m.add(i)
            m.add(n//i)
    m.remove(n)
    
    return m

z = False
a = int(input())
for i in range(1, 10 ** 4):
    f = dels(i)
    if len(f) == a and sum(dels(i)) == i:
        print(i)
        print(*dels(i))
        z = True
        break

if not z:
    print(-1)
