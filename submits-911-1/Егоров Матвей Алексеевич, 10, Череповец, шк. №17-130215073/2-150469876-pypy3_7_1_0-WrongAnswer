n=int(input())
s=[]
for i in range(1,n):
    if n%i==0:
        s.append(i)
q=w=e=0
for i in s:
    for a in s:
        for b in s:
            if i+b+a==n and i!=a and i!=b:
                q=i
                w=a
                e=b
if q==0 :
    print(-1)
else: 
    print(q+w+e)
    print(q,w,e)
