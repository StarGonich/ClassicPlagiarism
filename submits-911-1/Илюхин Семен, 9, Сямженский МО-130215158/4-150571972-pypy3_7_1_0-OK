def solve():
    n = int(input())
    k = int(input())
    
    best_d = 1
    import math
    limit = int(math.isqrt(n))

    for i in range(1, limit + 1):
        if n % i == 0:
            if i <= k and i > best_d:
                best_d = i

            j = n // i
            if j <= k and j > best_d:
                best_d = j

    p = n + best_d
    print(p)
    
if __name__ == '__main__':
	solve()
