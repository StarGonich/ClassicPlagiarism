def main():
    n = int(input())
    if n == 1:
        print(1)
        print(1)
    elif n == 2:
        print(-1)
    else:
        m = 3 * (2 ** (n - 2))
        divisors = [1, 2]
        for i in range(0, n - 2):
            divisors.append(3 * (2 ** i))
        print(m)
        print(' '.join(map(str, divisors)))

if __name__ == '__main__':
    main()