n = int(input())
k = int(input())
l = n+1
r = n+k
tempL = l
tempN = n
while(tempL != 0):
    tempN, tempL = tempL, tempN % tempL
lnok = n * l / tempN
while(l != r):
    m = (l + r) // 2
    tempM = m
    tempN = n
    while(tempM != 0):
        tempN, tempM = tempM, tempN % tempM
    nok = n * m / tempN
    if(lnok > nok):
        l = m
    else:
        r = m
    lnok = nok
print(l)
