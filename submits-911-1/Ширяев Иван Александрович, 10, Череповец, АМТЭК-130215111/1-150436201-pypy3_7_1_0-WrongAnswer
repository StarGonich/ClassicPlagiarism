h1 = int(input())
m1 = int(input())
h2 = int(input())
m2 = int(input())

if h2 < h1:
    h2 += 24
t1 = h1 * 60 + m1
t2 = h2 * 60 + m2
k = 0

for i in range(t1, t2 + 1):
    h = str(i // 60 % 24)
    m = str(i % 60)
    if len(h) == 1:
        h = '0' + h
    if len(m) == 1:
        m = '0' + m

    if h == m or h[::-1] == m:
        k += 1
    elif h == '01' and m == '23' or h == '12' and m == '34' or h == '23' and m == '45':
        k += 1
print(k)

