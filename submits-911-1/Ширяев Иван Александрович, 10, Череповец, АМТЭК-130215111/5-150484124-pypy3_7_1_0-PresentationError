k = int(input())
n = int(input())
m = int(input())
l = [0] * k
for i in range(k):
    l[i] = []
for i in range(k):
    for j in range(n):
        a = list(map(int, input().split()))
        l[i].append(a)
print(l)
r = [0] * n
for i in range(k):
    s = 0
    for j in range(n):
        s += sum(l[i][j])
    r[i] = [s , i]
r.sort(reverse=True)
for c in r:
    print(c[1] + 1, end=' ')

