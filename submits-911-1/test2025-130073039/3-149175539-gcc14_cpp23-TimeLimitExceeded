#include <iostream>
#include <vector>

#pragma GCC optimize("O3,unroll-loops")
#pragma GCC target("avx,avx2,fma")

using namespace std;

int main() {
   vector<bool> a(1'000'000'000);
   int n, T;
   cin >> n >> T;
   for (int k = 0; k < n; k++) {
      int t1, t2;
      cin >> t1 >> t2;
      for (int i = t1; i < t2; i++) {
         a[i] = 1;
      }
   }
   int adv = 0;
   for (int i = 0; i < 3600; i++) {
      adv += a[i];
   }
   if (adv > T) {
      cout << 0 << endl;
  //    cerr << "adv = " << adv << endl;
      return 0;
   }                            
   for (int i = 1; i < 1'000'000'000 - 3600 + 1; i++) {
      adv = adv - a[i-1] + a[i+3599];
      if (adv > T) {
         cout << i;
         return 0;
      }
   }
   cout << -1;
}
