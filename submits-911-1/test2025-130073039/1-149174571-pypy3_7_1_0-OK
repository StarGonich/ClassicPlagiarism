def beautiful(h, m):
   if h == m:
      return True   
   if h // 10 == m % 10 and h % 10 == m // 10:
      return True
   if h // 10 + 1 == h % 10 and h % 10 + 1 == m // 10 and m // 10 + 1 == m % 10:
      return True
   return False

h1 = int(input())
m1 = int(input())
h2 = int(input())
m2 = int(input())
ans = 0
while True:
   if beautiful(h1, m1):
      ans += 1
   if h1 == h2 and m1 == m2:
      break
   m1 += 1
   if m1 == 60:
      m1 = 0
      h1 += 1
      if h1 == 24:
         h1 = 0
print(ans)
