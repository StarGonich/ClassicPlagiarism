#include <algorithm>
#include <iostream>
#include <vector>

using namespace std;

void ProcessSimulation(vector<vector<int>>& field, bool &same) {
    vector<vector<int>> copyField = field;
    int n = field.size(), m = field[0].size();
    vector<int> X = {-1, -1, -1, 0, 0, 1, 1, 1};
    vector<int> Y = {-1,  0, 1, -1, 1, -1, 1, 0};
    for (int i = 0; i < (int) field.size(); i++) {
        for (int j = 0; j < (int) field[0].size(); j++) {
            size_t alive = 0;
            for (int p = 0; p < 8; p++) {
                if (0 <= i + X[p] && n > i + X[p] && 0 <= j + Y[p] && m > j + Y[p]) {
                    if (field[i + X[p]][j + Y[p]]) {
                        alive++;
                    }   
                }
            }
            if (alive == 2 && field[i][j]) {
                copyField[i][j] = 1;
            } else if (alive == 3) {
                copyField[i][j] = 1;
            } else {
                copyField[i][j] = 0;
            }
        }
    }
    if (field == copyField) {
        same = true;
    }
    field = copyField;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    int k, n, m;
    cin >> k >> n >> m;
    vector<vector<vector<int>>> fields(k, vector<vector<int>>(n, vector<int>(m)));
    for (int c = 0; c < k; c++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                cin >> fields[c][i][j];
            }
        }
    }
    vector<pair<int, int>> order(k);
    for (int i = 0; i < k; i++) {
        bool same = false;
        int cnt = 0;
        while (!same) {
            ProcessSimulation(fields[i], same);
            cnt++;
        }
        order[i].first = cnt;
        order[i].second = i;
    }
    sort(order.rbegin(), order.rend());
    for (auto el : order) {
        cout << el.second + 1 << ' ';
    }
    cout << endl;
}
