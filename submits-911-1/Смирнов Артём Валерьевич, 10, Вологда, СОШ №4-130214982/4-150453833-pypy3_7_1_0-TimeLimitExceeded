def gcd(a, b):
    """
    Вычисляет наибольший общий делитель (НОД) двух чисел a и b.
    Использует алгоритм Евклида.
    """
    while b:
        a, b = b, a % b
    return a

def lcm(a, b):
    """
    Вычисляет наименьшее общее кратное (НОК) двух чисел a и b.
    Использует формулу: НОК(a, b) = (a * b) // НОД(a, b).
    Использует целочисленное деление // чтобы избежать проблем с float.
    """
    return (a * b) // gcd(a, b)

n = int(input())
k = int(input())

best_p = -1       # Инициализация лучшего значения p
min_lcm = float('inf')  # Инициализация минимального НОК большим числом

# Итерируемся по возможным значениям p от n + 1 до n + k включительно.
# Дополнительно ограничим верхнюю границу 2 * n. Если p > 2 * n,
# то и lcm(n, p) > n * 2. Следовательно, можно итерироваться только до этого значения.
for p in range(n + 1, min(n + k + 1, 2 * n + 1)):    
    curr_lcm = lcm(n, p) # Вычисляем НОК для текущего p

    # Если найденное НОК меньше текущего минимального НОК,
    # обновляем минимальный НОК и лучшее значение p.
    if curr_lcm < min_lcm:
        min_lcm = curr_lcm
        best_p = p

print(best_p)