n = int(input())
m = 0
n1 = 0
n2 = 0
n3 = 0
if n/n == 1:
    m = m+n
if n % 2 == 0:
    m = m+2
if n/1 == n:
    m = m+1
if n%4 == 0:
    m = m+4
if n%6 == 0:
    m = m + 6
if n%8==0:
    m = m+8
for i in range(1, m):
    if m/i == 2:
        n2 = i
    if m/i == m:
        n1 = i
    if m/i == 1:
        n3 = i
        print(m)
        print(n1, n2, n3, sep=' ')
    else:
        print(-1)