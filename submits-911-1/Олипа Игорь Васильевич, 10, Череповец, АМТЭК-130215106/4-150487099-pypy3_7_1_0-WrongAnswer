n = int(input())
k = int(input())
##вычислим наим нок
delit = [1]
noki = []
n1 = n
i = 2
minnok = 0
minp = 10**18
while n1 > 1:
    if n1 % i == 0:
        n1 = n1 // i
        delit.append(i)
    else:
        i+=1
for i in range(len(delit)):
    nok = n * n // delit[len(delit) - 1 - i]
    for j in range(len(delit)):
        if n + 1 <= nok // delit[j] <= n + k:
            minp = min(minp, nok // delit[j])
print(minp)