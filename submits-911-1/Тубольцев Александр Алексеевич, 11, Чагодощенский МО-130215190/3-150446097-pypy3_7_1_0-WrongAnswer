n = int(input())
T = int(input())
r1 = []
r2 = []
for i in range(n):
    t1 , t2 = map(int, input().split())
    r1.append(t1)
    r2.append(t2)
l = r1[0]
r = l + 3600
c = 0
while l < r2[-1] + 1:
    for i in range(0, n):
        c += max(0, min(r2[i], r) - max(r1[i], l))
        if r < r1[i]:
            break
    if c > T:
        print(l)
        exit()
    else:
        l += 1
        r += 1
        c = 0
print(-1)