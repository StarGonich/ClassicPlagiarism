def der(d, n, k, m):
    if len(d) == k:
        if sum(d) == n:
            print(n)
            for x in d: print(x, end=" ")
            exit()
        ##print(d)
        return 0
    else:
        for i in range(m, n + 1, 1):
            if n % i == 0:
                dd = d.copy()
                der(dd, n, k, i + 1)
                d.add(i)
                der(d, n, k, i + 1)




