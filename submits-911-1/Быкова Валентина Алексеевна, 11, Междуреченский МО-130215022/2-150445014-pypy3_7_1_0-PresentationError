def find_number(n):
    if n == 1:
        return -1
    m = n * (n + 1) // 2
    divisors = list(range(1, n + 1))
    for d in divisors:
        if m % d != 0:
            return -1
    return m, divisors
n = int(input("Введите число"))
result = find_number(n)
if result == -1:
    print(-1)
else:
    m, divisors = result
    print(m)
    print(' '.join(map(str, divisors)))