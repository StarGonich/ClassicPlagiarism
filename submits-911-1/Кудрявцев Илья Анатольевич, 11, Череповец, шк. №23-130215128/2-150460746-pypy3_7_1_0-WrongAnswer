n = int(input())

def divs(m):
    a = []
    k=0
    for i in range(1, int(m**0.5)+1):
        if m%i==0 and i != m//i:
            k+=2
            a.append(i)
            a.append(m//i)
        elif m%i==0 and i == m//i:
            k+=1
            a.append(i)
    return k, a

for m in range(1, 10**9+1):
    a, b = divs(m)
    if a == n:
        print(m)
        print(*b)
        break