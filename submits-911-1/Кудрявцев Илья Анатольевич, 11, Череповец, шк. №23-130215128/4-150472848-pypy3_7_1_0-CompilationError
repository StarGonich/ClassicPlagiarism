from functools import lru_cache
@lru_cache:
n, k = int(input()), int(input())
def nok(a,b, m):
    c = max(a,b)
    while c%min(a,b) != 0:
        if c <= m:
            c += max(a,b)
        else:
            c = a*b
    return c
m=10**29
ans = 0
for p in range(n+1, n+k+1):
    if nok(n, p, m) < m:
        m = nok(n,p, m)
        ans = p
print(ans)