def main():
    n = int(input())
    cnt = 0
    for i in range(1, n + 1):
        curr_cnt = 0
        if i % 4 == 0:
            curr_cnt += 1
        if i % 5 == 0:
            curr_cnt += 1
        if i % 6 == 0:
            curr_cnt += 1
        if curr_cnt == 1:
            cnt += 1
    print(cnt)

main()