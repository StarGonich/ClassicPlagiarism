a,b,p = map(int, input().split())
c,d,q = map(int, input().split())

if a == c and b == d and p!=q: print('Contradiction')
elif a == c and b == d and p == q: print('Ambiguity')
else:
    m = []
    for x in range(1, 1000):
        for y in range(1,1000):
            if a/100*(x/10) + b/100*(y/10) == p and c/100*(x/10) + d/100*(y/10) == q:
                m.append(str(x/10))
                m.append(str(y/10))
    if not m: print('Not positive')
    else: print(' '.join(m))