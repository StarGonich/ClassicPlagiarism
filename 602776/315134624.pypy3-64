import sys

money = 210
loses = 0
stav = 0
m = 0
for _ in range(100):
    if loses == 3:
        stav = money
    else:
        stav = 1
    print(stav, "R")
    m = int(input())
    sys.stdin.flush()
    if (m == 0):
        money -= stav
        loses += 1
    if m == 1:
        money += stav
        loses = 0
    if m == -1:
        break
    if money >= 1000:
        break
