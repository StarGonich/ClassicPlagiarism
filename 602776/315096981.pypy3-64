def main():
    n = int(input())
    count = 0
    for i in range(1, n + 1):
        if i % 4 == 0 and i % 5 != 0 and i % 6 != 0:
            count += 1
        elif i % 4 != 0 and i % 5 == 0 and i % 6 != 0:
            count += 1
        elif i % 4 != 0 and i % 5 != 0 and i % 6 == 0:
            count += 1
    print(count)

if __name__ == '__main__':
    main()