
def main():
    n = int(input())

    if n < 4:
        print(0)
        return 0

    cnt = 0
    for i in range(1,n+1):
        if i % 4 == 0 and i % 5 != 0 and i % 6 != 0:
            cnt += 1
        if i % 5 == 0 and i % 4 != 0 and i % 6 != 0:
            cnt += 1
        if i % 6 == 0 and i % 5 != 0 and i % 4 != 0:
            cnt += 1
    print(cnt)
main()