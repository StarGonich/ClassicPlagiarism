
def main():
    n = int(input())

    cnt = 10 * (n // 30)
    n_start = 30 * (n//30)

    for i in range(n_start, n+1):
        if i % 4 == 0 and i % 5 != 0 and i % 6 != 0:
            cnt+=1
        if i % 5 == 0 and i % 4 != 0 and i % 6 != 0:
            cnt+=1
        if i % 6 == 0 and i % 5 != 0 and i % 4 != 0:
            cnt+=1

    print(int(cnt))
main()