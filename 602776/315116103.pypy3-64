a,b,p=map(int,input().split())
c,d,q=map(int,input().split())
a/=100
b/=100
c/=100
d/=100
if a==c and b==d and p==q:
    print('Ambiguity')
elif c*p-q*a==0 or c*b-d*a==0 or a==0 or(a>c and b>d and p<=q) or (a<c and b<d and p>=q) or (a==c and b==d and p!=q):
    print('Contradiction')
else:
    y=(c*p-q*a)/(c*b-d*a)
    x=(p-b*y)/a
    if x<0 or y<0:
        print('Not positive')
    else:
        print('Success')
        print(x,y)