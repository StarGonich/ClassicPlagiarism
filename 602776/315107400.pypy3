a1,b1,c1 = map(int,input().split())
a2,b2,c2=map(int,input().split())
if a1==0:
    print("Ambiguity")
    exit()
elif (b2-(a2*b1)/a1)==0 and (c2-(a2*c1)/a1)==0:
    print("Ambiguity")
    exit()
elif (b2-(a2*b1)/a1)==0 and (c2-(a2*c1)/a1)!=0:
    print("Contradiction")
    exit()
y = round((c2-(a2*c1)/a1)/(b2-(a2*b1)/a1)*100,1)
x = round((c1-b1*(c2-(a2*c1)/a1)/(b2-(a2*b1)/a1))/a1*100,1)
if x<0 or y<0:
    print("Not positive")
else:
    print("Success")
    print(x,y)
