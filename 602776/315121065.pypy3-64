f = [1, 2]
t = 1
n = 2
p = 2
mo = 10**9 + 7
for k in range(2,1000000):
##    print(p,t)
    p2 = ((p * 2) - t) % mo
    t = p - t
    n = (n * 2) % mo
    p = p2
    f.append(p)
f += [0]*4
n = int(input())
s = 0
for i in range(n-1):
##    print(i, max(1, f[i-1]), max(1, f[n - i - 3]))
    s += max(1, f[i-1]) * max(1, f[n - i - 3])
print(s % mo)