import sys
f = 1
cnt = 0
sumi = 210
stavka = sumi // 13
while f == 1:
    if cnt == 3:
        stavka = sumi
    print(stavka, "R")
    print()
    sys.stdout.flush()
    n = int(input())
    if (n == 1):
        sumi += stavka
        stavka = sumi // 16
    if (sumi >= 1000):
        exit()
    if (n == -1):
        exit()
    if (n == 0):
        sumi -= stavka
        stavka *= 2
        cnt += 1