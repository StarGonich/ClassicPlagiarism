import sys

money = 210
loses = 0
stav = 0
m = 0
while True:
    if loses == 3:
        stav = money
    else:
        stav = 1
    print(f"{stav} R")
    sys.stdout.flush()
    m = int(input())
    if (m == 0):
        money -= stav
        loses += 1
    elif m == 1:
        money += stav
        loses = 0
        if money >= 1000:
            break
    else:
        break