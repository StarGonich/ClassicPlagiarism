a, b, p = map(float, input().split())
c, d, q = map(float, input().split())

if a == c and b == d and p == q:
    print("Ambiguity")
    exit()
if a == c and b == d and p != q:
    print("Contradiction")
    exit()
r1 = ((p - (b/100) * (q/(d/100))) / (a/100)) / (1 - (((c/d) * (b/100)) / (a/100)))
r2 = (q - (c/100 * r1)) / (d/100)
print('Success')
print(round(r1, 3), round(r2, 3))