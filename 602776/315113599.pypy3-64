import sys
m = 210
lose = 0
while m < 1000:
    if lose == 3:
        print(m, 'R')
        print()
        sys.stdout.flush()
        w = int(input())
        print()
        m *= 2
        sys.stdout.flush()
        lose = 0
    else:
        print(1, 'R')
        print()
        sys.stdout.flush()
        w = int(input())
        print()
        sys.stdout.flush()
        if w:
            m += 1
            lose = 0
        else:
            lose += 1
            m -= 1