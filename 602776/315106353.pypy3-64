def f(s, t):
    if t == 1:
        a = ""
        for i in s:
            a += i * 3
        return a
    if t == 2:
        for i in range(len(s) - 2, 3):
            if not(s[i] == s[i+1] == s[i+2]):
                if s[i] == s[i+1]:
                    s[i+2] = s[i]
                elif s[i] == s[i+2]:
                    s[i+1] = s[i]
                else:
                    s[i] = s[i+1]
        return s[::3]


s = input()
t = int(input())
print(f(s,t))