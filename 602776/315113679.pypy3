import sys
n = 1
por = 0
bal = 210
while n<=100 and bal<1000:
    print("вывод:",flush=1)
    if por==3:
        print(bal,"R",flush=1)
    else:
        print(1,"R",flush=1)
    print("ввод:",flush=1)
    m = int(input())
    if m==1:
        bal*=2
        por = 0
    else:
        bal-=1
        por+=1
