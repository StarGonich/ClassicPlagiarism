s = 210
flag = 1
stav = 0
res = 0
for i in range(100):
    if flag == 1:
        stav = s//15    
    print(stav * flag, "R")

    res = int(input())
    
    if res == -1:
        break
    elif res == 1: 
        s += (stav * flag)
        flag = 1
    elif res == 0:
        s -= (stav * flag)
        flag *= 2
    if s >= 1000:
        break